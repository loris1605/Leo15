<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lc="using:Leonardo"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:r="using:ReactiveUI.Avalonia"
             xmlns:vm="using:ViewModels"
             xmlns:ui="using:ControlStyles"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="LightSteelBlue"
             x:DataType="vm:ListaSociViewModel"
             x:Class="Views.ListaSociView">

    <Grid x:Name="MainGrid">
    
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TITOLO -->
            <RowDefinition Height="*"/> <!-- DATAGRID -->
            <RowDefinition Height="Auto"/> <!-- PULSANTI -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <lc:TitleView TitoloPagina="ELENCO SOCI ALL'INTERNO"
                      x:Name="Title"
                      ButtonText="Esci"
                      ToolTipText="TORNA A POSTAZIONE"
                      ExitCommand="{Binding EscPressedCommand}"/>


    
    </Grid>
  
</UserControl>
